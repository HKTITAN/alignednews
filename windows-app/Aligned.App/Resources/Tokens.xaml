<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
      Hand-mirrored from ../../design/tokens.json. Keep in sync.
      Use {ThemeResource AlignedBg}, {ThemeResource AlignedText}, etc.
    -->
    <ResourceDictionary.ThemeDictionaries>

        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="AlignedBg"            Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="AlignedSurface"       Color="#FFF5F5F7"/>
            <SolidColorBrush x:Key="AlignedElev1"         Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="AlignedElev2"         Color="#FFFBFBFD"/>
            <SolidColorBrush x:Key="AlignedText"          Color="#FF1D1D1F"/>
            <SolidColorBrush x:Key="AlignedTextSecondary" Color="#FF6E6E73"/>
            <SolidColorBrush x:Key="AlignedTextTertiary"  Color="#FF86868B"/>
            <SolidColorBrush x:Key="AlignedSeparator"     Color="#FFD2D2D7"/>
            <SolidColorBrush x:Key="AlignedAccent"        Color="#FF0A84FF"/>
            <SolidColorBrush x:Key="AlignedDestructive"   Color="#FFFF3B30"/>
            <SolidColorBrush x:Key="AlignedSuccess"       Color="#FF34C759"/>
            <SolidColorBrush x:Key="AlignedWarning"       Color="#FFFF9500"/>
            <SolidColorBrush x:Key="AlignedOnAccent"      Color="#FFFFFFFF"/>
        </ResourceDictionary>

        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="AlignedBg"            Color="#FF000000"/>
            <SolidColorBrush x:Key="AlignedSurface"       Color="#FF1C1C1E"/>
            <SolidColorBrush x:Key="AlignedElev1"         Color="#FF2C2C2E"/>
            <SolidColorBrush x:Key="AlignedElev2"         Color="#FF3A3A3C"/>
            <SolidColorBrush x:Key="AlignedText"          Color="#FFF5F5F7"/>
            <SolidColorBrush x:Key="AlignedTextSecondary" Color="#FF98989D"/>
            <SolidColorBrush x:Key="AlignedTextTertiary"  Color="#FF6E6E73"/>
            <SolidColorBrush x:Key="AlignedSeparator"     Color="#FF38383A"/>
            <SolidColorBrush x:Key="AlignedAccent"        Color="#FF0A84FF"/>
            <SolidColorBrush x:Key="AlignedDestructive"   Color="#FFFF453A"/>
            <SolidColorBrush x:Key="AlignedSuccess"       Color="#FF30D158"/>
            <SolidColorBrush x:Key="AlignedWarning"       Color="#FFFF9F0A"/>
            <SolidColorBrush x:Key="AlignedOnAccent"      Color="#FFFFFFFF"/>
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!-- Geometry-agnostic constants (sizes, radii, durations) -->
    <x:Double x:Key="AlignedRadiusTap">12</x:Double>
    <x:Double x:Key="AlignedRadiusCard">16</x:Double>
    <x:Double x:Key="AlignedRadiusSheet">24</x:Double>
    <CornerRadius x:Key="AlignedCardCorner">16</CornerRadius>
    <CornerRadius x:Key="AlignedTapCorner">12</CornerRadius>
    <CornerRadius x:Key="AlignedChipCorner">100</CornerRadius>

    <Thickness x:Key="AlignedPaddingCard">16,16,16,16</Thickness>
    <Thickness x:Key="AlignedPaddingScreen">24,20,24,16</Thickness>
    <Thickness x:Key="AlignedPaddingChip">12,7,12,7</Thickness>

    <!-- Typography -->
    <FontFamily x:Key="AlignedFontDisplay">Segoe UI Variable Display</FontFamily>
    <FontFamily x:Key="AlignedFontText">Segoe UI Variable Text</FontFamily>
    <FontFamily x:Key="AlignedFontMono">Cascadia Mono</FontFamily>

    <!-- Type ramp (matches design/tokens.json scale) -->
    <Style x:Key="AlignedDisplayLg" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AlignedFontDisplay}"/>
        <Setter Property="FontSize" Value="34"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="LineHeight" Value="41"/>
        <Setter Property="CharacterSpacing" Value="-12"/>
    </Style>
    <Style x:Key="AlignedDisplayMd" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AlignedFontDisplay}"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="LineHeight" Value="34"/>
        <Setter Property="CharacterSpacing" Value="-11"/>
    </Style>
    <Style x:Key="AlignedTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AlignedFontDisplay}"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="LineHeight" Value="28"/>
        <Setter Property="CharacterSpacing" Value="-9"/>
    </Style>
    <Style x:Key="AlignedTitleSm" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AlignedFontDisplay}"/>
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="LineHeight" Value="22"/>
    </Style>
    <Style x:Key="AlignedBody" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AlignedFontText}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="LineHeight" Value="21"/>
    </Style>
    <Style x:Key="AlignedFootnote" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AlignedFontText}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="LineHeight" Value="18"/>
    </Style>
    <Style x:Key="AlignedCaption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AlignedFontText}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="LineHeight" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="CharacterSpacing" Value="60"/>
    </Style>

    <!-- Common chrome -->
    <Style x:Key="AlignedCardBorder" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AlignedElev1}"/>
        <Setter Property="CornerRadius" Value="{StaticResource AlignedCardCorner}"/>
        <Setter Property="Padding" Value="{StaticResource AlignedPaddingCard}"/>
    </Style>

</ResourceDictionary>
