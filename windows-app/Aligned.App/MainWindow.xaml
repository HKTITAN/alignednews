<Window
    x:Class="Aligned.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctl="using:Aligned.App.Controls"
    Title="ALIGNED">

    <Grid Background="{ThemeResource AlignedBg}">

        <NavigationView x:Name="Nav"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        PaneDisplayMode="LeftCompact"
                        OpenPaneLength="240"
                        IsPaneToggleButtonVisible="True"
                        SelectionChanged="OnNavSelected">

            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent"/>
                <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="Transparent"/>
            </NavigationView.Resources>

            <NavigationView.PaneHeader>
                <StackPanel Orientation="Horizontal" Padding="14,12" Spacing="10">
                    <ctl:MorphingIcon Width="20" Height="20"
                                      Spec="{x:Bind ctl:MorphingIcons.Sparkle}"
                                      IconBrush="{ThemeResource AlignedText}"/>
                    <TextBlock Text="ALIGNED"
                               FontFamily="{StaticResource AlignedFontDisplay}"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{ThemeResource AlignedText}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Feed" Tag="feed" IsSelected="True">
                    <NavigationViewItem.Icon><PathIcon Data="M5 12 L7 3 L9 12 M5 12 L9 12"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Today" Tag="brief">
                    <NavigationViewItem.Icon><PathIcon Data="M7 1 L7 13 M1 7 L13 7"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Map" Tag="map">
                    <NavigationViewItem.Icon><PathIcon Data="M2 7 L12 7 M7 2 L7 12 M3 4 L11 4"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Events" Tag="events">
                    <NavigationViewItem.Icon><PathIcon Data="M2 4 L12 4 M2 4 L2 12 M12 4 L12 12"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Search" Tag="search">
                    <NavigationViewItem.Icon><PathIcon Data="M3 3 L9 3 M3 3 L3 9 M7 7 L12 12"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemSeparator/>
                <NavigationViewItemHeader Content="AI tools"/>
                <NavigationViewItem Content="Ask" Tag="chat">
                    <NavigationViewItem.Icon><PathIcon Data="M5 3 L5 9 M9 3 L9 9 M4 12 L10 12"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Summarize link" Tag="summarize">
                    <NavigationViewItem.Icon><PathIcon Data="M7 12 L7 2 M3 5 L7 2 M7 2 L11 5"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Research" Tag="research">
                    <NavigationViewItem.Icon><PathIcon Data="M7 1 L7 13 M1 7 L13 7"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemSeparator/>
                <NavigationViewItemHeader Content="Library"/>
                <NavigationViewItem Content="Bookmarks" Tag="bookmarks">
                    <NavigationViewItem.Icon><PathIcon Data="M4 2 L4 12 M10 2 L10 12 M4 12 L10 12"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="History" Tag="history">
                    <NavigationViewItem.Icon><PathIcon Data="M2 7 L7 2 M7 2 L12 7"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Categories" Tag="categories">
                    <NavigationViewItem.Icon><PathIcon Data="M7 2 L7 12 M4 5 L10 5 M5 8 L9 8"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Sources" Tag="accounts">
                    <NavigationViewItem.Icon><PathIcon Data="M3 5 L7 9 M11 5 L7 9 M2 7 L12 7"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemSeparator/>
                <NavigationViewItem Content="Settings" Tag="settings">
                    <NavigationViewItem.Icon><PathIcon Data="M4 2 L4 8 M7 5 L7 12 M10 2 L10 10"/></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" Background="Transparent"/>
        </NavigationView>
    </Grid>
</Window>
