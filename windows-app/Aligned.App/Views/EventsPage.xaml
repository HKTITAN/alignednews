<Page
    x:Class="Aligned.App.Views.EventsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Aligned.App.ViewModels"
    Background="{ThemeResource AlignedBg}">

    <Page.DataContext>
        <vm:EventsViewModel/>
    </Page.DataContext>

    <Grid Padding="{StaticResource AlignedPaddingScreen}" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock Text="Events" Style="{StaticResource AlignedDisplayMd}"
                       Foreground="{ThemeResource AlignedText}"/>
            <TextBlock Text="{x:Bind ViewModel.Subtitle, Mode=OneWay}"
                       Style="{StaticResource AlignedFootnote}"
                       Foreground="{ThemeResource AlignedTextSecondary}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Visibility="{x:Bind ViewModel.LoadingVisibility, Mode=OneWay}"
                          Width="28" Height="28"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Foreground="{ThemeResource AlignedText}"/>
            <TextBlock Visibility="{x:Bind ViewModel.ErrorVisibility, Mode=OneWay}"
                       Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{ThemeResource AlignedDestructive}"
                       Style="{StaticResource AlignedFootnote}"/>
            <ScrollViewer Visibility="{x:Bind ViewModel.ContentVisibility, Mode=OneWay}">
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Events, Mode=OneWay}" Margin="0,0,4,40">
                    <ItemsRepeater.Layout><StackLayout Spacing="10"/></ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:EventVm">
                            <Border Style="{StaticResource AlignedCardBorder}">
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <Ellipse Width="8" Height="8">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{x:Bind DotColor}"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Text="{x:Bind DateLabel}"
                                                   Style="{StaticResource AlignedCaption}"
                                                   Foreground="{ThemeResource AlignedTextSecondary}"/>
                                        <TextBlock Text="{x:Bind LocationLabel}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource AlignedTextTertiary}"/>
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind Name}"
                                               Style="{StaticResource AlignedTitleSm}"
                                               Foreground="{ThemeResource AlignedText}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{x:Bind Description}"
                                               Style="{StaticResource AlignedBody}"
                                               Foreground="{ThemeResource AlignedTextSecondary}"
                                               TextWrapping="Wrap"
                                               MaxLines="3"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
