<Page
    x:Class="Aligned.App.Views.FeedPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Aligned.App.ViewModels"
    xmlns:dto="using:Aligned.Core.Net.Dto"
    xmlns:ctl="using:Aligned.App.Controls"
    Background="{ThemeResource AlignedBg}">

    <Page.DataContext>
        <vm:FeedViewModel/>
    </Page.DataContext>

    <Grid Padding="{StaticResource AlignedPaddingScreen}" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="ALIGNED"
                           FontFamily="{StaticResource AlignedFontDisplay}"
                           FontSize="28" FontWeight="Bold"
                           Foreground="{ThemeResource AlignedText}"/>
                <TextBlock Foreground="{ThemeResource AlignedTextSecondary}"
                           FontSize="13">
                    <Run Text="{x:Bind ViewModel.Stories.Count, Mode=OneWay}"/>
                    <Run Text=" stories · realtime"/>
                </TextBlock>
            </StackPanel>
            <Button Grid.Column="1"
                    Command="{x:Bind ViewModel.LoadCommand}"
                    Background="Transparent"
                    BorderThickness="0">
                <ctl:MorphingIcon Width="22" Height="22"
                                  Spec="{x:Bind ctl:MorphingIcons.Refresh}"
                                  IconBrush="{ThemeResource AlignedText}"/>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollMode="Auto" VerticalScrollBarVisibility="Auto">
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Stories, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="12"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="dto:StoryDto">
                        <Button HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="{ThemeResource AlignedElev1}"
                                BorderBrush="{ThemeResource AlignedSeparator}"
                                BorderThickness="0"
                                CornerRadius="{StaticResource AlignedCardCorner}"
                                Padding="{StaticResource AlignedPaddingCard}"
                                Click="OnStoryClick"
                                Tag="{x:Bind Id}">
                            <StackPanel Spacing="6" HorizontalAlignment="Stretch">
                                <TextBlock Text="{x:Bind Category}"
                                           FontSize="11" FontWeight="Medium"
                                           Foreground="{ThemeResource AlignedTextSecondary}"/>
                                <TextBlock Text="{x:Bind Headline}"
                                           FontFamily="{StaticResource AlignedFontDisplay}"
                                           FontSize="17" FontWeight="SemiBold"
                                           TextWrapping="Wrap" MaxLines="3"
                                           HorizontalAlignment="Left"
                                           Foreground="{ThemeResource AlignedText}"/>
                                <TextBlock Text="{x:Bind Summary}"
                                           FontSize="15"
                                           TextWrapping="Wrap" MaxLines="3"
                                           HorizontalAlignment="Left"
                                           Foreground="{ThemeResource AlignedTextSecondary}"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
</Page>
