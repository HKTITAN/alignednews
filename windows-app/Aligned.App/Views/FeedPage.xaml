<Page
    x:Class="Aligned.App.Views.FeedPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Aligned.App.ViewModels"
    xmlns:dto="using:Aligned.Core.Net.Dto"
    xmlns:ctl="using:Aligned.App.Controls"
    Background="{ThemeResource AlignedBg}">

    <Page.DataContext>
        <vm:FeedViewModel/>
    </Page.DataContext>

    <Grid Padding="{StaticResource AlignedPaddingScreen}" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Feed" Style="{StaticResource AlignedDisplayMd}"
                           Foreground="{ThemeResource AlignedText}"/>
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="{x:Bind ViewModel.LiveDotColor, Mode=OneWay}"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Style="{StaticResource AlignedFootnote}"
                               Foreground="{ThemeResource AlignedTextSecondary}"
                               Text="{x:Bind ViewModel.StatusLine, Mode=OneWay}"/>
                </StackPanel>
            </StackPanel>
            <Button Grid.Column="1"
                    Command="{x:Bind ViewModel.LoadCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="10" CornerRadius="{StaticResource AlignedTapCorner}"
                    ToolTipService.ToolTip="Refresh">
                <ctl:MorphingIcon Width="20" Height="20"
                                  Spec="{x:Bind ctl:MorphingIcons.Refresh}"
                                  IconBrush="{ThemeResource AlignedText}"/>
            </Button>
        </Grid>

        <!-- Category filter -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollMode="Auto"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollMode="Disabled"
                      VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{x:Bind ViewModel.CategoryChips, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:CategoryChip">
                        <Button Command="{x:Bind SelectCommand}"
                                Background="{x:Bind BackgroundBrush, Mode=OneWay}"
                                BorderThickness="0"
                                CornerRadius="{StaticResource AlignedChipCorner}"
                                Padding="{StaticResource AlignedPaddingChip}">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Ellipse Width="7" Height="7" Visibility="{x:Bind DotVisibility}">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{x:Bind DotColor}"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="{x:Bind Label}"
                                           FontSize="13" FontWeight="Medium"
                                           Foreground="{x:Bind ForegroundBrush, Mode=OneWay}"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Body -->
        <Grid Grid.Row="2">
            <!-- Loading -->
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Visibility="{x:Bind ViewModel.IsLoadingVisibility, Mode=OneWay}"
                          Width="32" Height="32"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Foreground="{ThemeResource AlignedText}"/>

            <!-- Error -->
            <StackPanel Visibility="{x:Bind ViewModel.ErrorVisibility, Mode=OneWay}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="8" MaxWidth="360">
                <TextBlock Style="{StaticResource AlignedTitleSm}"
                           Foreground="{ThemeResource AlignedText}"
                           HorizontalAlignment="Center"
                           Text="Couldn't reach alignednews.ai"/>
                <TextBlock Style="{StaticResource AlignedFootnote}"
                           HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                           Foreground="{ThemeResource AlignedTextSecondary}"
                           Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"/>
                <Button Command="{x:Bind ViewModel.LoadCommand}"
                        HorizontalAlignment="Center"
                        Background="{ThemeResource AlignedAccent}"
                        BorderThickness="0"
                        CornerRadius="{StaticResource AlignedChipCorner}"
                        Padding="16,8">
                    <TextBlock Text="Try again" Foreground="{ThemeResource AlignedOnAccent}"
                               FontSize="13" FontWeight="SemiBold"/>
                </Button>
            </StackPanel>

            <!-- List -->
            <ScrollViewer Visibility="{x:Bind ViewModel.ListVisibility, Mode=OneWay}"
                          VerticalScrollMode="Auto" VerticalScrollBarVisibility="Auto"
                          Padding="0,0,4,0">
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.FilteredStories, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="12"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="dto:StoryDto">
                            <Button HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Background="{ThemeResource AlignedElev1}"
                                    BorderThickness="0"
                                    CornerRadius="{StaticResource AlignedCardCorner}"
                                    Padding="{StaticResource AlignedPaddingCard}"
                                    Click="OnStoryClick"
                                    Tag="{x:Bind Id}">
                                <StackPanel Spacing="10" HorizontalAlignment="Stretch">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{x:Bind vm:FeedViewModel.CategoryColor(Category)}"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Text="{x:Bind vm:FeedViewModel.PrettyCategory(Category)}"
                                                   Style="{StaticResource AlignedCaption}"
                                                   Foreground="{ThemeResource AlignedTextSecondary}"/>
                                        <TextBlock Text="·"
                                                   Foreground="{ThemeResource AlignedTextTertiary}"
                                                   FontSize="11"/>
                                        <TextBlock Text="{x:Bind vm:FeedViewModel.MetaLine(TweetCount, TotalEngagement)}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource AlignedTextTertiary}"/>
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind Headline}"
                                               FontFamily="{StaticResource AlignedFontDisplay}"
                                               FontSize="18" FontWeight="SemiBold"
                                               TextWrapping="Wrap" MaxLines="3"
                                               HorizontalAlignment="Left"
                                               Foreground="{ThemeResource AlignedText}"/>
                                    <TextBlock Text="{x:Bind Summary}"
                                               Style="{StaticResource AlignedBody}"
                                               TextWrapping="Wrap" MaxLines="3"
                                               HorizontalAlignment="Left"
                                               Foreground="{ThemeResource AlignedTextSecondary}"/>
                                    <Image Source="{x:Bind HeroImageUrl}"
                                           Visibility="{x:Bind vm:FeedViewModel.NonEmptyVisibility(HeroImageUrl)}"
                                           Height="160" Stretch="UniformToFill"
                                           HorizontalAlignment="Stretch"
                                           ImageFailed="OnImageFailed"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
