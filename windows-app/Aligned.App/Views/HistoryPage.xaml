<Page
    x:Class="Aligned.App.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Aligned.App.ViewModels"
    xmlns:ctl="using:Aligned.App.Controls"
    Background="{ThemeResource AlignedBg}">

    <Page.DataContext>
        <vm:HistoryViewModel/>
    </Page.DataContext>

    <Grid Padding="{StaticResource AlignedPaddingScreen}" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock Text="History" Style="{StaticResource AlignedDisplayMd}"
                       Foreground="{ThemeResource AlignedText}"/>
            <TextBlock Text="{x:Bind ViewModel.Subtitle, Mode=OneWay}"
                       Style="{StaticResource AlignedFootnote}"
                       Foreground="{ThemeResource AlignedTextSecondary}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Visibility="{x:Bind ViewModel.LoadingVisibility, Mode=OneWay}"
                          Width="28" Height="28"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Foreground="{ThemeResource AlignedText}"/>
            <TextBlock Visibility="{x:Bind ViewModel.ErrorVisibility, Mode=OneWay}"
                       Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{ThemeResource AlignedDestructive}"
                       Style="{StaticResource AlignedFootnote}"/>
            <ScrollViewer Visibility="{x:Bind ViewModel.ContentVisibility, Mode=OneWay}">
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Entries, Mode=OneWay}" Margin="0,0,4,40">
                    <ItemsRepeater.Layout><StackLayout Spacing="10"/></ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:HistoryEntryVm">
                            <Border Style="{StaticResource AlignedCardBorder}">
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <ctl:MorphingIcon Width="12" Height="12"
                                                          Spec="{x:Bind GlyphSpec}"
                                                          IconBrush="{ThemeResource AlignedTextSecondary}"
                                                          VerticalAlignment="Center"/>
                                        <TextBlock Text="{x:Bind TypeLabel}"
                                                   Style="{StaticResource AlignedCaption}"
                                                   Foreground="{ThemeResource AlignedTextSecondary}"/>
                                        <TextBlock Text="{x:Bind WhenLabel}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource AlignedTextTertiary}"/>
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind Query}"
                                               FontSize="15" FontWeight="SemiBold"
                                               TextWrapping="Wrap" MaxLines="3"
                                               Foreground="{ThemeResource AlignedText}"/>
                                    <TextBlock Text="{x:Bind ConfidenceLine}"
                                               FontSize="12"
                                               Foreground="{ThemeResource AlignedTextTertiary}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
