<Page
    x:Class="Aligned.App.Views.CategoriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Aligned.App.ViewModels"
    xmlns:ctl="using:Aligned.App.Controls"
    Background="{ThemeResource AlignedBg}">

    <Page.DataContext>
        <vm:CategoriesViewModel/>
    </Page.DataContext>

    <Grid Padding="{StaticResource AlignedPaddingScreen}" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock Text="Categories" Style="{StaticResource AlignedDisplayMd}"
                       Foreground="{ThemeResource AlignedText}"/>
            <TextBlock Text="{x:Bind ViewModel.Subtitle, Mode=OneWay}"
                       Style="{StaticResource AlignedFootnote}"
                       Foreground="{ThemeResource AlignedTextSecondary}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Visibility="{x:Bind ViewModel.LoadingVisibility, Mode=OneWay}"
                          Width="28" Height="28"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Foreground="{ThemeResource AlignedText}"/>
            <TextBlock Visibility="{x:Bind ViewModel.ErrorVisibility, Mode=OneWay}"
                       Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{ThemeResource AlignedDestructive}"
                       Style="{StaticResource AlignedFootnote}"/>
            <ScrollViewer Visibility="{x:Bind ViewModel.ContentVisibility, Mode=OneWay}">
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}" Margin="0,0,4,40">
                    <ItemsRepeater.Layout><StackLayout Spacing="6"/></ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:CategoryRowVm">
                            <Button Command="{x:Bind TogglePinCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Background="{ThemeResource AlignedElev1}"
                                    BorderThickness="0"
                                    CornerRadius="{StaticResource AlignedCardCorner}"
                                    Padding="14,12">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Grid.Column="0" Width="10" Height="10" VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{x:Bind DotColor}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="{x:Bind Label}"
                                                   Foreground="{ThemeResource AlignedText}"
                                                   FontSize="15" FontWeight="Medium"/>
                                        <TextBlock Text="{x:Bind Id}"
                                                   Foreground="{ThemeResource AlignedTextTertiary}"
                                                   FontSize="11"/>
                                    </StackPanel>
                                    <ctl:MorphingIcon Grid.Column="2" Width="18" Height="18"
                                                      VerticalAlignment="Center"
                                                      Spec="{x:Bind ctl:MorphingIcons.Pin}"
                                                      IconBrush="{x:Bind PinBrush, Mode=OneWay}"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
