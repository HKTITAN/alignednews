<Page
    x:Class="Aligned.App.Views.StoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Aligned.App.ViewModels"
    xmlns:dto="using:Aligned.Core.Net.Dto"
    xmlns:ctl="using:Aligned.App.Controls"
    Background="{ThemeResource AlignedBg}">

    <Page.DataContext>
        <vm:StoryDetailViewModel/>
    </Page.DataContext>

    <ScrollViewer Padding="{StaticResource AlignedPaddingScreen}">
        <StackPanel Spacing="16" MaxWidth="720" HorizontalAlignment="Stretch">

            <!-- Category -->
            <TextBlock Text="{x:Bind ViewModel.Story.Category, Mode=OneWay}"
                       FontSize="11" FontWeight="Medium"
                       Foreground="{ThemeResource AlignedTextSecondary}"/>

            <!-- Headline -->
            <TextBlock Text="{x:Bind ViewModel.Story.Headline, Mode=OneWay}"
                       FontFamily="{StaticResource AlignedFontDisplay}"
                       FontSize="28" FontWeight="Bold"
                       TextWrapping="Wrap"
                       Foreground="{ThemeResource AlignedText}"/>

            <!-- Summary -->
            <TextBlock Text="{x:Bind ViewModel.Story.Summary, Mode=OneWay}"
                       FontSize="17" LineHeight="24"
                       TextWrapping="Wrap"
                       Foreground="{ThemeResource AlignedTextSecondary}"/>

            <!-- Vote bar -->
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Command="{x:Bind ViewModel.VoteUpCommand}"
                        Background="{ThemeResource AlignedElev1}"
                        BorderBrush="{ThemeResource AlignedSeparator}"
                        Padding="14,8" CornerRadius="100">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ctl:MorphingIcon Width="16" Height="16"
                                          Spec="{x:Bind ctl:MorphingIcons.Check}"
                                          IconBrush="{ThemeResource AlignedText}"/>
                        <TextBlock Text="Useful" Foreground="{ThemeResource AlignedText}" FontSize="14"/>
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.VoteDownCommand}"
                        Background="{ThemeResource AlignedElev1}"
                        BorderBrush="{ThemeResource AlignedSeparator}"
                        Padding="14,8" CornerRadius="100">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ctl:MorphingIcon Width="16" Height="16"
                                          Spec="{x:Bind ctl:MorphingIcons.Close}"
                                          IconBrush="{ThemeResource AlignedText}"/>
                        <TextBlock Text="Not useful" Foreground="{ThemeResource AlignedText}" FontSize="14"/>
                    </StackPanel>
                </Button>
                <TextBlock VerticalAlignment="Center" FontSize="13"
                           Text="{x:Bind ViewModel.LastVote, Mode=OneWay}"
                           Foreground="{ThemeResource AlignedTextSecondary}"/>
            </StackPanel>

            <Rectangle Height="0.5" Fill="{ThemeResource AlignedSeparator}"/>

            <!-- Tweets -->
            <TextBlock Text="Source posts" FontSize="13" FontWeight="SemiBold"
                       Foreground="{ThemeResource AlignedTextSecondary}"/>

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Tweets, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="12"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="dto:TweetDto">
                        <Border Background="{ThemeResource AlignedElev1}"
                                CornerRadius="{StaticResource AlignedCardCorner}"
                                Padding="{StaticResource AlignedPaddingCard}">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind AuthorName}" FontWeight="SemiBold"
                                               Foreground="{ThemeResource AlignedText}" FontSize="14"/>
                                    <TextBlock Text="{x:Bind AuthorUsername}" Foreground="{ThemeResource AlignedTextSecondary}" FontSize="13"/>
                                </StackPanel>
                                <TextBlock Text="{x:Bind Text}" TextWrapping="Wrap"
                                           Foreground="{ThemeResource AlignedText}" FontSize="15" LineHeight="20"/>
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <TextBlock Text="{x:Bind Likes}"    Foreground="{ThemeResource AlignedTextTertiary}" FontSize="12"/>
                                    <TextBlock Text="{x:Bind Retweets}" Foreground="{ThemeResource AlignedTextTertiary}" FontSize="12"/>
                                    <TextBlock Text="{x:Bind Replies}"  Foreground="{ThemeResource AlignedTextTertiary}" FontSize="12"/>
                                    <TextBlock Text="{x:Bind Views}"    Foreground="{ThemeResource AlignedTextTertiary}" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

        </StackPanel>
    </ScrollViewer>
</Page>
