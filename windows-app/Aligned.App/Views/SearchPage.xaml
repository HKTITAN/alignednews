<Page
    x:Class="Aligned.App.Views.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Aligned.App.ViewModels"
    xmlns:dto="using:Aligned.Core.Net.Dto"
    xmlns:ctl="using:Aligned.App.Controls"
    Background="{ThemeResource AlignedBg}">

    <Page.DataContext>
        <vm:SearchViewModel/>
    </Page.DataContext>

    <Grid Padding="{StaticResource AlignedPaddingScreen}" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Search"
                   Style="{StaticResource AlignedDisplayMd}"
                   Foreground="{ThemeResource AlignedText}"/>

        <Border Grid.Row="1"
                Background="{ThemeResource AlignedElev1}"
                CornerRadius="{StaticResource AlignedChipCorner}"
                Padding="14,8">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ctl:MorphingIcon Grid.Column="0" Width="16" Height="16" VerticalAlignment="Center"
                                  Spec="{x:Bind ctl:MorphingIcons.Search}"
                                  IconBrush="{ThemeResource AlignedTextSecondary}"/>
                <TextBox Grid.Column="1"
                         Text="{x:Bind ViewModel.Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Search stories…"
                         BorderThickness="0"
                         Background="Transparent"
                         FontSize="15"
                         VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <TextBlock Visibility="{x:Bind ViewModel.IdleVisibility, Mode=OneWay}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{ThemeResource AlignedTextSecondary}"
                       Style="{StaticResource AlignedFootnote}"
                       Text="Search the live AI news feed."/>
            <ProgressRing IsActive="{x:Bind ViewModel.IsSearching, Mode=OneWay}"
                          Visibility="{x:Bind ViewModel.SearchingVisibility, Mode=OneWay}"
                          Width="24" Height="24"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Foreground="{ThemeResource AlignedText}"/>
            <TextBlock Visibility="{x:Bind ViewModel.NoResultsVisibility, Mode=OneWay}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{ThemeResource AlignedTextSecondary}"
                       Style="{StaticResource AlignedFootnote}"
                       Text="{x:Bind ViewModel.NoResultsText, Mode=OneWay}"/>
            <ScrollViewer Visibility="{x:Bind ViewModel.ResultsVisibility, Mode=OneWay}">
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Results, Mode=OneWay}" Margin="0,0,4,40">
                    <ItemsRepeater.Layout><StackLayout Spacing="10"/></ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="dto:StoryDto">
                            <Button HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Background="{ThemeResource AlignedElev1}"
                                    BorderThickness="0"
                                    CornerRadius="{StaticResource AlignedCardCorner}"
                                    Padding="14"
                                    Click="OnResultClick"
                                    Tag="{x:Bind Id}">
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <Ellipse Width="8" Height="8">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{x:Bind vm:FeedViewModel.CategoryColor(Category)}"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Text="{x:Bind vm:FeedViewModel.PrettyCategory(Category)}"
                                                   Style="{StaticResource AlignedCaption}"
                                                   Foreground="{ThemeResource AlignedTextSecondary}"/>
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind Headline}"
                                               FontFamily="{StaticResource AlignedFontDisplay}"
                                               FontSize="15" FontWeight="SemiBold"
                                               TextWrapping="Wrap" MaxLines="3"
                                               Foreground="{ThemeResource AlignedText}"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
