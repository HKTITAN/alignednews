<Page
    x:Class="Aligned.App.Views.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Aligned.App.ViewModels"
    xmlns:ctl="using:Aligned.App.Controls"
    Background="{ThemeResource AlignedBg}">

    <Page.DataContext>
        <vm:ChatViewModel/>
    </Page.DataContext>

    <Grid Padding="{StaticResource AlignedPaddingScreen}" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="Ask" Style="{StaticResource AlignedDisplayMd}"
                           Foreground="{ThemeResource AlignedText}"/>
                <TextBlock Text="{x:Bind ViewModel.SubtitleLine, Mode=OneWay}"
                           Style="{StaticResource AlignedFootnote}"
                           Foreground="{ThemeResource AlignedTextSecondary}"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Command="{x:Bind ViewModel.ClearCommand}"
                    Visibility="{x:Bind ViewModel.ClearVisibility, Mode=OneWay}"
                    Background="Transparent" BorderThickness="0"
                    Padding="10" CornerRadius="{StaticResource AlignedTapCorner}"
                    ToolTipService.ToolTip="Clear chat">
                <ctl:MorphingIcon Width="18" Height="18"
                                  Spec="{x:Bind ctl:MorphingIcons.Close}"
                                  IconBrush="{ThemeResource AlignedText}"/>
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <!-- Empty -->
            <StackPanel Visibility="{x:Bind ViewModel.EmptyVisibility, Mode=OneWay}"
                        VerticalAlignment="Center" HorizontalAlignment="Stretch"
                        MaxWidth="640" Spacing="20">
                <StackPanel Spacing="6">
                    <TextBlock Text="Ask anything about today's news."
                               FontFamily="{StaticResource AlignedFontDisplay}"
                               FontSize="22" FontWeight="SemiBold" LineHeight="28"
                               Foreground="{ThemeResource AlignedText}"/>
                    <TextBlock Text="Answers stream token-by-token from the live feed."
                               Style="{StaticResource AlignedBody}"
                               Foreground="{ThemeResource AlignedTextSecondary}"/>
                </StackPanel>
                <ItemsControl ItemsSource="{x:Bind ViewModel.Suggestions, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Spacing="8"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SuggestionItem">
                            <Button Command="{x:Bind PickCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Background="{ThemeResource AlignedElev1}"
                                    BorderThickness="0"
                                    CornerRadius="{StaticResource AlignedCardCorner}"
                                    Padding="14,12">
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <ctl:MorphingIcon Width="14" Height="14"
                                                      Spec="{x:Bind ctl:MorphingIcons.Sparkle}"
                                                      IconBrush="{ThemeResource AlignedTextSecondary}"/>
                                    <TextBlock Text="{x:Bind Text}"
                                               Foreground="{ThemeResource AlignedText}" FontSize="14"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Messages -->
            <ScrollViewer x:Name="MessagesScroll"
                          Visibility="{x:Bind ViewModel.ListVisibility, Mode=OneWay}"
                          VerticalScrollMode="Auto" VerticalScrollBarVisibility="Auto">
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="10"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:ChatMessage">
                            <Grid>
                                <Border Background="{x:Bind BubbleBrush, Mode=OneWay}"
                                        CornerRadius="{x:Bind BubbleCorner, Mode=OneWay}"
                                        Padding="14,10"
                                        MaxWidth="540"
                                        HorizontalAlignment="{x:Bind BubbleAlignment, Mode=OneWay}">
                                    <TextBlock Text="{x:Bind Content, Mode=OneWay}"
                                               Foreground="{x:Bind BubbleTextBrush, Mode=OneWay}"
                                               FontSize="15" LineHeight="22"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>

        <!-- Composer -->
        <Border Grid.Row="2"
                Background="{ThemeResource AlignedElev1}"
                CornerRadius="28"
                Padding="14,8">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{x:Bind ViewModel.Input, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Ask anything about today's news…"
                         BorderThickness="0"
                         Background="Transparent"
                         FontSize="15"
                         VerticalAlignment="Center"
                         KeyDown="OnComposerKeyDown"
                         AcceptsReturn="False"/>
                <Button Grid.Column="1"
                        Click="OnSendClick"
                        Background="{x:Bind ViewModel.SendButtonBrush, Mode=OneWay}"
                        BorderThickness="0"
                        CornerRadius="100"
                        Padding="10">
                    <ctl:MorphingIcon Width="18" Height="18"
                                      Spec="{x:Bind ViewModel.SendIcon, Mode=OneWay}"
                                      IconBrush="{x:Bind ViewModel.SendIconBrush, Mode=OneWay}"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>
