<Page
    x:Class="Aligned.App.Views.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Aligned.App.ViewModels"
    xmlns:ctl="using:Aligned.App.Controls"
    Background="{ThemeResource AlignedBg}">

    <Page.DataContext>
        <vm:ChatViewModel/>
    </Page.DataContext>

    <Grid Padding="20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0">
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="12"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:ChatMessage">
                        <Border Background="{ThemeResource AlignedElev1}"
                                CornerRadius="{StaticResource AlignedCardCorner}"
                                Padding="14,10"
                                HorizontalAlignment="Stretch">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{x:Bind Role, Mode=OneWay}"
                                           FontSize="11" FontWeight="Medium"
                                           Foreground="{ThemeResource AlignedTextSecondary}"/>
                                <TextBlock Text="{x:Bind Content, Mode=OneWay}"
                                           FontSize="15" LineHeight="22"
                                           TextWrapping="Wrap"
                                           Foreground="{ThemeResource AlignedText}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <!-- Composer -->
        <Border Grid.Row="1"
                Background="{ThemeResource AlignedElev1}"
                CornerRadius="{StaticResource AlignedCardCorner}"
                Padding="12,8" BorderThickness="1"
                BorderBrush="{ThemeResource AlignedSeparator}">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{x:Bind ViewModel.Input, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Ask anything about today's news..."
                         BorderThickness="0"
                         Background="Transparent"
                         FontSize="15"
                         AcceptsReturn="False"/>
                <Button Grid.Column="1"
                        Command="{x:Bind ViewModel.SendCommand}"
                        Background="{ThemeResource AlignedAccent}"
                        BorderThickness="0"
                        CornerRadius="100"
                        Padding="12,8">
                    <ctl:MorphingIcon Width="16" Height="16"
                                      Spec="{x:Bind ctl:MorphingIcons.Send}"
                                      IconBrush="White"/>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>
