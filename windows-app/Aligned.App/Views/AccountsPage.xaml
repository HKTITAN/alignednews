<Page
    x:Class="Aligned.App.Views.AccountsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Aligned.App.ViewModels"
    xmlns:ctl="using:Aligned.App.Controls"
    Background="{ThemeResource AlignedBg}">

    <Page.DataContext>
        <vm:AccountsViewModel/>
    </Page.DataContext>

    <Grid Padding="{StaticResource AlignedPaddingScreen}" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock Text="Sources" Style="{StaticResource AlignedDisplayMd}"
                       Foreground="{ThemeResource AlignedText}"/>
            <TextBlock Text="{x:Bind ViewModel.Subtitle, Mode=OneWay}"
                       Style="{StaticResource AlignedFootnote}"
                       Foreground="{ThemeResource AlignedTextSecondary}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Visibility="{x:Bind ViewModel.LoadingVisibility, Mode=OneWay}"
                          Width="28" Height="28"
                          HorizontalAlignment="Center" VerticalAlignment="Center"
                          Foreground="{ThemeResource AlignedText}"/>
            <TextBlock Visibility="{x:Bind ViewModel.ErrorVisibility, Mode=OneWay}"
                       Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{ThemeResource AlignedDestructive}"
                       Style="{StaticResource AlignedFootnote}"/>
            <ScrollViewer Visibility="{x:Bind ViewModel.ContentVisibility, Mode=OneWay}">
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Accounts, Mode=OneWay}" Margin="0,0,4,40">
                    <ItemsRepeater.Layout><StackLayout Spacing="10"/></ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:AccountVm">
                            <Button Command="{x:Bind OpenCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Background="{ThemeResource AlignedElev1}"
                                    BorderThickness="0"
                                    CornerRadius="{StaticResource AlignedCardCorner}"
                                    Padding="14">
                                <StackPanel Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <Ellipse Width="44" Height="44">
                                            <Ellipse.Fill>
                                                <ImageBrush ImageSource="{x:Bind ProfileImage}"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <StackPanel Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Name}"
                                                       FontSize="15" FontWeight="SemiBold"
                                                       Foreground="{ThemeResource AlignedText}"/>
                                            <TextBlock Foreground="{ThemeResource AlignedTextSecondary}" FontSize="12">
                                                <Run Text="@"/>
                                                <Run Text="{x:Bind Username}"/>
                                                <Run Text="  ·  "/>
                                                <Run Text="{x:Bind FollowersLabel}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind Description}"
                                               Style="{StaticResource AlignedFootnote}"
                                               Foreground="{ThemeResource AlignedTextSecondary}"
                                               TextWrapping="Wrap" MaxLines="3"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
