{
  "$schema": "./tokens.schema.json",
  "meta": {
    "name": "ALIGNED Design Tokens",
    "version": "0.1.0",
    "description": "Single source of truth for color, typography, spacing, motion. Consumed by both android-app and windows-app.",
    "fontSubstitutions": {
      "ios":     { "SF Pro Display": "SF Pro Display", "SF Pro Text": "SF Pro Text", "SF Mono": "SF Mono" },
      "android": { "SF Pro Display": "Inter",          "SF Pro Text": "Inter",       "SF Mono": "JetBrains Mono" },
      "windows": { "SF Pro Display": "Segoe UI Variable Display", "SF Pro Text": "Segoe UI Variable Text", "SF Mono": "Cascadia Mono" }
    }
  },

  "color": {
    "light": {
      "bg":             "#FFFFFF",
      "surface":        "#F5F5F7",
      "elev1":          "#FFFFFF",
      "elev2":          "#FBFBFD",
      "text":           "#1D1D1F",
      "textSecondary":  "#6E6E73",
      "textTertiary":   "#86868B",
      "separator":      "#D2D2D7",
      "separatorOpaque":"#C6C6C8",
      "accent":         "#0A84FF",
      "destructive":    "#FF3B30",
      "success":        "#34C759",
      "warning":        "#FF9500",
      "scrim":          "#00000033"
    },
    "dark": {
      "bg":             "#000000",
      "surface":        "#1C1C1E",
      "elev1":          "#2C2C2E",
      "elev2":          "#3A3A3C",
      "text":           "#F5F5F7",
      "textSecondary":  "#98989D",
      "textTertiary":   "#6E6E73",
      "separator":      "#38383A",
      "separatorOpaque":"#48484A",
      "accent":         "#0A84FF",
      "destructive":    "#FF453A",
      "success":        "#30D158",
      "warning":        "#FF9F0A",
      "scrim":          "#000000B3"
    },
    "category": {
      "_comment": "Mirrors /api/categories. Single source = what the backend ships. These are fallback values if the API call hasn't returned yet.",
      "ai-headlines":       "#3B82F6",
      "ai-companies":       "#6366F1",
      "ai-papers":          "#A78BFA",
      "ai-models":          "#818CF8",
      "ai-events":          "#0EA5E9",
      "ai-scoble":          "#F59E0B",
      "ai-conversations":   "#10B981",
      "ai-safety":          "#F87171",
      "ai-robotics":        "#FB923C",
      "ai-vehicles":        "#16A34A",
      "creative-ai":        "#F472B6",
      "ai-decentralized":   "#EAB308",
      "ai-spatial":         "#14B8A6",
      "ai-videos":          "#8B5CF6",
      "ai-agents":          "#06B6D4",
      "ai-entrepreneurs":   "#A855F7",
      "ai-investors":       "#34D399",
      "ai-neuro":           "#EC4899",
      "world-models":       "#2DD4BF",
      "other-tech":         "#06B6D4",
      "general-news":       "#EF4444",
      "business-news":      "#10B981",
      "crypto":             "#FBBF24",
      "climate":            "#4ADE80",
      "space":              "#818CF8",
      "politics":           "#EF4444",
      "entertainment":      "#EC4899",
      "xai-news":           "#1D4ED8",
      "ev-tesla":           "#16A34A",
      "quantum":            "#7C3AED",
      "dev-tools":          "#0891B2",
      "ai-education":       "#D946EF",
      "health-biotech":     "#F43F5E",
      "china-global-ai":    "#DC2626",
      "ai-tech":            "#3B82F6",
      "business":           "#10B981",
      "science":            "#8B5CF6",
      "world":              "#F59E0B",
      "sports":             "#06B6D4",
      "funding":            "#34D399",
      "research":           "#A78BFA",
      "robotics":           "#FB923C"
    }
  },

  "type": {
    "displayLg":    { "font": "SF Pro Display", "size": 34, "lineHeight": 41, "weight": 700, "tracking": -0.40 },
    "displayMd":    { "font": "SF Pro Display", "size": 28, "lineHeight": 34, "weight": 700, "tracking": -0.30 },
    "title":        { "font": "SF Pro Display", "size": 22, "lineHeight": 28, "weight": 600, "tracking": -0.20 },
    "titleSm":      { "font": "SF Pro Display", "size": 17, "lineHeight": 22, "weight": 600, "tracking": -0.10 },
    "body":         { "font": "SF Pro Text",    "size": 17, "lineHeight": 22, "weight": 400, "tracking": -0.10 },
    "bodyEmph":     { "font": "SF Pro Text",    "size": 17, "lineHeight": 22, "weight": 600, "tracking": -0.10 },
    "callout":      { "font": "SF Pro Text",    "size": 16, "lineHeight": 21, "weight": 400, "tracking":  0.00 },
    "subhead":      { "font": "SF Pro Text",    "size": 15, "lineHeight": 20, "weight": 400, "tracking":  0.00 },
    "footnote":     { "font": "SF Pro Text",    "size": 13, "lineHeight": 18, "weight": 400, "tracking":  0.00 },
    "caption":      { "font": "SF Pro Text",    "size": 12, "lineHeight": 16, "weight": 400, "tracking":  0.00 },
    "mono":         { "font": "SF Mono",        "size": 13, "lineHeight": 18, "weight": 400, "tracking":  0.00 }
  },

  "space": { "0": 0, "1": 4, "2": 8, "3": 12, "4": 16, "5": 20, "6": 24, "7": 32, "8": 40, "9": 48, "10": 64, "11": 80 },

  "radius": {
    "tap":   12,
    "card":  16,
    "sheet": 24,
    "chip":  100,
    "icon":  6
  },

  "elevation": {
    "_comment": "Subtle elevation only; the aesthetic is flat-with-borders, not Material drop shadows.",
    "card":  { "y": 0, "blur": 0, "spread": 0, "color": "transparent", "border": "separator" },
    "sheet": { "y": 12, "blur": 32, "spread": 0, "color": "#0000001F" },
    "popover":{ "y": 8, "blur": 24, "spread": 0, "color": "#00000026" }
  },

  "motion": {
    "spring": { "stiffness": 380, "damping": 30, "mass": 1 },
    "springSnappy": { "stiffness": 600, "damping": 36, "mass": 1 },
    "springSoft":   { "stiffness": 220, "damping": 26, "mass": 1 },
    "duration": { "fast": 120, "base": 220, "slow": 360, "long": 600 },
    "easing": {
      "standard":  [0.20, 0.80, 0.20, 1.00],
      "decelerate":[0.05, 0.70, 0.10, 1.00],
      "accelerate":[0.30, 0.00, 1.00, 1.00]
    },
    "icon": {
      "_comment": "Morphing icon defaults — per-line spring, same for all coordinates within an icon",
      "spring":   { "stiffness": 420, "damping": 32 },
      "rotation": { "stiffness": 500, "damping": 30 }
    }
  },

  "icon": {
    "viewBox":  [0, 0, 14, 14],
    "stroke":   2,
    "linecap":  "round",
    "linejoin": "round",
    "collapse": { "x": 7, "y": 7 }
  },

  "tap": {
    "minTarget": 44,
    "pressScale": 0.97,
    "pressDuration": 96
  }
}
